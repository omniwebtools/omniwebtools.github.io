<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Case Converter – ToolBox</title>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #f5f2eb;
      --ink: #1a1a1a;
      --muted: #888;
      --border: #d8d3c8;
      --card: #ffffff;
      --accent-yellow: #f5c842;
      --accent-red: #e84040;
      --radius: 16px;
    }

    body {
      background: var(--bg);
      color: var(--ink);
      font-family: 'DM Sans', sans-serif;
      min-height: 100vh;
      overflow-x: hidden;
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 0;
      opacity: 0.5;
    }

    /* HEADER */
    header {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(245,242,235,0.92);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
      padding: 0 40px;
      height: 64px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .logo {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.9rem;
      letter-spacing: 0.06em;
      color: var(--ink);
      line-height: 1;
      text-decoration: none;
    }

    .logo sup {
      font-family: 'DM Mono', monospace;
      font-size: 0.5rem;
      background: var(--accent-yellow);
      color: var(--ink);
      padding: 2px 6px;
      border-radius: 4px;
      vertical-align: super;
      letter-spacing: 0.05em;
      font-weight: 500;
    }

    .back-btn {
      font-family: 'DM Mono', monospace;
      font-size: 0.68rem;
      color: var(--muted);
      letter-spacing: 0.1em;
      text-transform: uppercase;
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 6px;
      transition: color 0.2s;
    }

    .back-btn:hover { color: var(--ink); }

    /* HERO */
    .hero {
      position: relative;
      z-index: 1;
      padding: 60px 40px 40px;
      max-width: 1100px;
      margin: 0 auto;
    }

    .hero-eyebrow {
      font-family: 'DM Mono', monospace;
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: var(--muted);
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .hero-eyebrow::before {
      content: '';
      width: 30px;
      height: 1px;
      background: var(--muted);
    }

    .hero h1 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(3rem, 8vw, 6rem);
      line-height: 0.95;
      letter-spacing: 0.02em;
      color: var(--ink);
      margin-bottom: 16px;
    }

    .hero h1 .highlight {
      color: var(--accent-red);
      position: relative;
      display: inline-block;
    }

    .hero h1 .highlight::after {
      content: '';
      position: absolute;
      bottom: 4px;
      left: 0;
      right: 0;
      height: 5px;
      background: var(--accent-yellow);
      z-index: -1;
      transform: skewX(-3deg);
    }

    .hero-desc {
      font-size: 0.95rem;
      color: var(--muted);
      line-height: 1.7;
      max-width: 500px;
    }

    /* MAIN SECTION */
    .section {
      position: relative;
      z-index: 1;
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 40px 80px;
    }

    .section-label {
      font-family: 'DM Mono', monospace;
      font-size: 0.68rem;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: var(--muted);
      margin-bottom: 20px;
      padding-bottom: 12px;
      border-bottom: 1px solid var(--border);
    }

    /* INPUT CARD */
    .input-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
      margin-bottom: 16px;
      transition: border-color 0.2s;
    }

    .input-card:focus-within {
      border-color: var(--accent-yellow);
    }

    .card-header {
      padding: 14px 20px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: #fafaf8;
    }

    .card-header-label {
      font-family: 'DM Mono', monospace;
      font-size: 0.65rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--muted);
    }

    .stats {
      display: flex;
      gap: 16px;
    }

    .stat {
      font-family: 'DM Mono', monospace;
      font-size: 0.65rem;
      color: var(--muted);
    }

    .stat span {
      color: var(--ink);
      font-weight: 500;
    }

    textarea {
      width: 100%;
      min-height: 180px;
      background: transparent;
      border: none;
      outline: none;
      color: var(--ink);
      font-family: 'DM Mono', monospace;
      font-size: 0.9rem;
      line-height: 1.8;
      padding: 20px;
      resize: vertical;
    }

    textarea::placeholder { color: #c5c0b5; }

    .card-footer {
      padding: 10px 16px;
      border-top: 1px solid var(--border);
      background: #fafaf8;
      display: flex;
      justify-content: flex-end;
    }

    .clear-btn {
      font-family: 'DM Mono', monospace;
      font-size: 0.65rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      background: none;
      border: 1px solid var(--border);
      color: var(--muted);
      padding: 5px 14px;
      border-radius: 100px;
      cursor: pointer;
      transition: all 0.15s;
    }

    .clear-btn:hover { border-color: var(--accent-red); color: var(--accent-red); }

    /* CASE BUTTONS GRID */
    .cases-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 10px;
      margin-bottom: 16px;
    }

    .case-btn {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 18px 20px;
      cursor: pointer;
      text-align: left;
      transition: all 0.2s;
      position: relative;
      overflow: hidden;
    }

    .case-btn::after {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
      background: var(--accent-yellow);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.25s ease;
    }

    .case-btn:hover {
      border-color: var(--accent-yellow);
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(0,0,0,0.07);
    }

    .case-btn:hover::after { transform: scaleX(1); }

    .case-btn.active {
      border-color: var(--accent-yellow);
      background: #fffbee;
    }

    .case-btn.active::after { transform: scaleX(1); }

    .btn-name {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.1rem;
      letter-spacing: 0.05em;
      color: var(--ink);
      display: block;
      margin-bottom: 4px;
    }

    .btn-preview {
      font-family: 'DM Mono', monospace;
      font-size: 0.62rem;
      color: var(--muted);
    }

    /* OUTPUT CARD */
    .output-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
    }

    .output-text {
      padding: 20px;
      font-family: 'DM Mono', monospace;
      font-size: 0.9rem;
      line-height: 1.8;
      color: var(--ink);
      min-height: 100px;
      word-break: break-word;
      white-space: pre-wrap;
    }

    .output-text.empty {
      color: #c5c0b5;
    }

    .output-text.empty::before {
      content: 'Your converted text will appear here…';
    }

    .copy-btn {
      font-family: 'DM Mono', monospace;
      font-size: 0.65rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      background: var(--ink);
      color: var(--bg);
      border: none;
      padding: 8px 18px;
      border-radius: 100px;
      cursor: pointer;
      transition: all 0.15s;
    }

    .copy-btn:hover { background: #333; }
    .copy-btn.copied { background: #16a34a; }

    /* INFO SECTION */
    .info-section {
      position: relative;
      z-index: 1;
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 40px 80px;
    }

    .info-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 12px;
    }

    .info-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 20px;
    }

    .info-card h3 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1rem;
      letter-spacing: 0.05em;
      color: var(--ink);
      margin-bottom: 6px;
    }

    .info-card p {
      font-size: 0.78rem;
      color: var(--muted);
      line-height: 1.6;
    }

    /* FOOTER */
    footer {
      position: relative;
      z-index: 1;
      border-top: 1px solid var(--border);
      padding: 28px 40px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .footer-logo {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.2rem;
      letter-spacing: 0.06em;
      color: var(--muted);
    }

    .footer-note {
      font-family: 'DM Mono', monospace;
      font-size: 0.62rem;
      color: var(--muted);
      letter-spacing: 0.08em;
    }

    /* TOAST */
    .toast {
      position: fixed;
      bottom: 28px;
      right: 28px;
      background: var(--ink);
      color: var(--bg);
      font-family: 'DM Mono', monospace;
      font-size: 0.72rem;
      letter-spacing: 0.08em;
      padding: 12px 20px;
      border-radius: 100px;
      transform: translateY(60px);
      opacity: 0;
      transition: all 0.3s cubic-bezier(0.34,1.56,0.64,1);
      pointer-events: none;
      z-index: 999;
    }

    .toast.show { transform: translateY(0); opacity: 1; }

    /* FADE IN ANIMATION */
    .fade-in {
      opacity: 0;
      transform: translateY(16px);
      animation: fadeUp 0.4s ease forwards;
    }

    @keyframes fadeUp { to { opacity: 1; transform: translateY(0); } }

    .fade-in:nth-child(1) { animation-delay: 0.05s; }
    .fade-in:nth-child(2) { animation-delay: 0.1s; }
    .fade-in:nth-child(3) { animation-delay: 0.15s; }
    .fade-in:nth-child(4) { animation-delay: 0.2s; }
    .fade-in:nth-child(5) { animation-delay: 0.25s; }
    .fade-in:nth-child(6) { animation-delay: 0.3s; }
    .fade-in:nth-child(7) { animation-delay: 0.35s; }
    .fade-in:nth-child(8) { animation-delay: 0.4s; }
    .fade-in:nth-child(9) { animation-delay: 0.45s; }
    .fade-in:nth-child(10) { animation-delay: 0.5s; }
    .fade-in:nth-child(11) { animation-delay: 0.55s; }
    .fade-in:nth-child(12) { animation-delay: 0.6s; }

    @media (max-width: 600px) {
      header { padding: 0 20px; }
      .hero, .section, .info-section { padding-left: 20px; padding-right: 20px; }
      .cases-grid { grid-template-columns: 1fr 1fr; }
      footer { padding: 20px; flex-direction: column; gap: 8px; text-align: center; }
    }
  </style>
</head>
<body>

<header>
  <a href="index.html" class="logo">ToolBox <sup>FREE</sup></a>
  <a href="index.html" class="back-btn">← All Tools</a>
</header>

<section class="hero">
  <div class="hero-eyebrow">Text Tool</div>
  <h1><span class="highlight">Case</span><br>Converter.</h1>
  <p class="hero-desc">Paste your text, pick a case — done. 12 formats supported, works instantly in your browser.</p>
</section>

<div class="section">
  <div class="section-label">// your text</div>

  <div class="input-card">
    <div class="card-header">
      <span class="card-header-label">Input</span>
      <div class="stats">
        <div class="stat">chars <span id="charCount">0</span></div>
        <div class="stat">words <span id="wordCount">0</span></div>
        <div class="stat">lines <span id="lineCount">0</span></div>
      </div>
    </div>
    <textarea id="inputText" placeholder="Type or paste your text here…"></textarea>
    <div class="card-footer">
      <button class="clear-btn" id="clearBtn">✕ Clear</button>
    </div>
  </div>

  <div class="section-label" style="margin-top: 32px;">// pick a case</div>

  <div class="cases-grid">
    <button class="case-btn fade-in" data-case="sentence"><span class="btn-name">Sentence case</span><span class="btn-preview">This is sentence case.</span></button>
    <button class="case-btn fade-in" data-case="lower"><span class="btn-name">lower case</span><span class="btn-preview">this is lower case.</span></button>
    <button class="case-btn fade-in" data-case="upper"><span class="btn-name">UPPER CASE</span><span class="btn-preview">THIS IS UPPER CASE.</span></button>
    <button class="case-btn fade-in" data-case="capitalized"><span class="btn-name">Capitalized Case</span><span class="btn-preview">This Is Capitalized Case.</span></button>
    <button class="case-btn fade-in" data-case="alternating"><span class="btn-name">aLtErNaTiNg</span><span class="btn-preview">tHiS Is aLtErNaTiNg.</span></button>
    <button class="case-btn fade-in" data-case="title"><span class="btn-name">Title Case</span><span class="btn-preview">This Is a Title Case.</span></button>
    <button class="case-btn fade-in" data-case="inverse"><span class="btn-name">iNVERSE cASE</span><span class="btn-preview">tHIS iS iNVERSE cASE.</span></button>
    <button class="case-btn fade-in" data-case="camel"><span class="btn-name">camelCase</span><span class="btn-preview">thisIsCamelCase</span></button>
    <button class="case-btn fade-in" data-case="pascal"><span class="btn-name">PascalCase</span><span class="btn-preview">ThisIsPascalCase</span></button>
    <button class="case-btn fade-in" data-case="snake"><span class="btn-name">snake_case</span><span class="btn-preview">this_is_snake_case</span></button>
    <button class="case-btn fade-in" data-case="kebab"><span class="btn-name">kebab-case</span><span class="btn-preview">this-is-kebab-case</span></button>
    <button class="case-btn fade-in" data-case="constant"><span class="btn-name">CONSTANT_CASE</span><span class="btn-preview">THIS_IS_CONSTANT_CASE</span></button>
  </div>

  <div class="section-label" style="margin-top: 32px;">// output</div>

  <div class="output-card">
    <div class="card-header">
      <span class="card-header-label" id="activeLabel">Select a case above</span>
      <button class="copy-btn" id="copyBtn">Copy to Clipboard</button>
    </div>
    <div class="output-text empty" id="outputBox"></div>
  </div>
</div>

<div class="info-section">
  <div class="section-label">// all 12 cases explained</div>
  <div class="info-grid">
    <div class="info-card"><h3>Sentence case</h3><p>Capitalizes the first letter of each sentence. Great for fixing accidental caps-lock text.</p></div>
    <div class="info-card"><h3>lower case</h3><p>Converts every letter to lowercase. Useful for normalizing input or casual writing styles.</p></div>
    <div class="info-card"><h3>UPPER CASE</h3><p>Makes all letters capitals. Perfect for headings, shouts, and acronyms.</p></div>
    <div class="info-card"><h3>Capitalized Case</h3><p>First letter of every word is capitalized. Common for names and titles.</p></div>
    <div class="info-card"><h3>aLtErNaTiNg cAsE</h3><p>Alternates between lower and upper on each character. Fun mocking-spongebob vibes.</p></div>
    <div class="info-card"><h3>Title Case</h3><p>Capitalizes important words, skipping articles and prepositions. Ideal for article headlines.</p></div>
    <div class="info-card"><h3>iNVERSE cASE</h3><p>Flips the case of every letter — uppercase becomes lowercase and vice versa.</p></div>
    <div class="info-card"><h3>camelCase</h3><p>No spaces, each word starts with a capital except the first. Standard in JavaScript variables.</p></div>
    <div class="info-card"><h3>PascalCase</h3><p>Like camelCase but the first word is also capitalized. Used for class names in most languages.</p></div>
    <div class="info-card"><h3>snake_case</h3><p>Words joined by underscores in lowercase. Popular in Python and database column names.</p></div>
    <div class="info-card"><h3>kebab-case</h3><p>Words joined by hyphens in lowercase. Standard for URLs, CSS class names, and file names.</p></div>
    <div class="info-card"><h3>CONSTANT_CASE</h3><p>All caps with underscores. Used for constants and environment variables in most languages.</p></div>
  </div>
</div>

<footer>
  <div class="footer-logo">ToolBox</div>
  <div class="footer-note">Free · No signup · No tracking</div>
</footer>

<div class="toast" id="toast">✓ Copied to clipboard</div>

<script>
  var MINORS = {'a':1,'an':1,'the':1,'and':1,'but':1,'or':1,'nor':1,'for':1,'so':1,'yet':1,'at':1,'by':1,'in':1,'of':1,'on':1,'to':1,'up':1,'as':1,'is':1,'it':1};

  var converters = {
    sentence: function(t) { return t.toLowerCase().replace(/(^\s*\w|[.!?]\s+\w)/g, function(c){ return c.toUpperCase(); }); },
    lower: function(t) { return t.toLowerCase(); },
    upper: function(t) { return t.toUpperCase(); },
    capitalized: function(t) { return t.toLowerCase().replace(/\b\w/g, function(c){ return c.toUpperCase(); }); },
    alternating: function(t) { return t.split('').map(function(c,i){ return i%2===0 ? c.toLowerCase() : c.toUpperCase(); }).join(''); },
    title: function(t) {
      var words = t.toLowerCase().split(' ');
      return words.map(function(w, i) {
        if (i === 0 || i === words.length - 1 || !MINORS[w]) return w.replace(/^\w/, function(c){ return c.toUpperCase(); });
        return w;
      }).join(' ');
    },
    inverse: function(t) { return t.split('').map(function(c){ return c === c.toUpperCase() ? c.toLowerCase() : c.toUpperCase(); }).join(''); },
    camel: function(t) { return t.trim().split(/[\s_\-]+/).map(function(w,i){ return i===0 ? w.toLowerCase() : w.charAt(0).toUpperCase()+w.slice(1).toLowerCase(); }).join(''); },
    pascal: function(t) { return t.trim().split(/[\s_\-]+/).map(function(w){ return w.charAt(0).toUpperCase()+w.slice(1).toLowerCase(); }).join(''); },
    snake: function(t) { return t.trim().replace(/[\s\-]+/g,'_').replace(/([a-z])([A-Z])/g,'$1_$2').toLowerCase(); },
    kebab: function(t) { return t.trim().replace(/[\s_]+/g,'-').replace(/([a-z])([A-Z])/g,'$1-$2').toLowerCase(); },
    constant: function(t) { return t.trim().replace(/[\s\-]+/g,'_').replace(/([a-z])([A-Z])/g,'$1_$2').toUpperCase(); }
  };

  var caseLabels = {
    sentence:'Sentence Case', lower:'lower case', upper:'UPPER CASE',
    capitalized:'Capitalized Case', alternating:'aLtErNaTiNg cAsE', title:'Title Case',
    inverse:'iNVERSE cASE', camel:'camelCase', pascal:'PascalCase',
    snake:'snake_case', kebab:'kebab-case', constant:'CONSTANT_CASE'
  };

  var currentCase = null;

  function updateStats() {
    var text = document.getElementById('inputText').value;
    document.getElementById('charCount').textContent = text.length;
    document.getElementById('wordCount').textContent = text.trim() === '' ? 0 : text.trim().split(/\s+/).length;
    document.getElementById('lineCount').textContent = text === '' ? 0 : text.split('\n').length;
  }

  function applyCase(type) {
    currentCase = type;
    document.querySelectorAll('.case-btn').forEach(function(b) { b.classList.remove('active'); });
    document.querySelector('[data-case="' + type + '"]').classList.add('active');
    var input = document.getElementById('inputText').value;
    var outputBox = document.getElementById('outputBox');
    if (input.trim() === '') {
      outputBox.textContent = '';
      outputBox.classList.add('empty');
    } else {
      outputBox.textContent = converters[type](input);
      outputBox.classList.remove('empty');
    }
    document.getElementById('activeLabel').textContent = caseLabels[type];
  }

  document.getElementById('inputText').addEventListener('input', function() {
    updateStats();
    if (currentCase) applyCase(currentCase);
  });

  document.querySelectorAll('.case-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      applyCase(this.getAttribute('data-case'));
    });
  });

  document.getElementById('clearBtn').addEventListener('click', function() {
    document.getElementById('inputText').value = '';
    var outputBox = document.getElementById('outputBox');
    outputBox.textContent = '';
    outputBox.classList.add('empty');
    document.getElementById('activeLabel').textContent = 'Select a case above';
    document.querySelectorAll('.case-btn').forEach(function(b) { b.classList.remove('active'); });
    currentCase = null;
    updateStats();
  });

  document.getElementById('copyBtn').addEventListener('click', function() {
    var text = document.getElementById('outputBox').textContent;
    if (!text || document.getElementById('outputBox').classList.contains('empty')) return;
    navigator.clipboard.writeText(text).then(function() {
      var btn = document.getElementById('copyBtn');
      btn.textContent = '✓ Copied!';
      btn.classList.add('copied');
      var toast = document.getElementById('toast');
      toast.classList.add('show');
      setTimeout(function() {
        btn.textContent = 'Copy to Clipboard';
        btn.classList.remove('copied');
        toast.classList.remove('show');
      }, 2000);
    });
  });
</script>
</body>
</html>
